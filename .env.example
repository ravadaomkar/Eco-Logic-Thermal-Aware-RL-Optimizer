# eco-logic/.env.example
# Copy this file to .env and fill in your values.

# Dell OpenManage Enterprise
OME_HOST=https://192.168.1.100
OME_USER=admin
OME_PASSWORD=your_password_here

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ecologic
MYSQL_PASSWORD=ecologic
MYSQL_DB=ecologic

# Prometheus
PROMETHEUS_PORT=8000

# Logging
LOG_LEVEL=INFO
